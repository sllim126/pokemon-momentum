[Unit]
Description=Pokemon Momentum Weekly Full Metadata Refresh
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/pokemon-momentum
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=DAILY_WORKERS=4
Environment=PIPELINE_ARGS=--full-metadata-refresh
ExecStart=/opt/pokemon-momentum/scripts/pipeline/run_daily_update_host.sh
User=root
Group=root

